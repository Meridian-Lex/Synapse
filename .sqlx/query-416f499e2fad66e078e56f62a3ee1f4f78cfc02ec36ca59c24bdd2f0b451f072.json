{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT a.id, a.name, a.fleet_id, a.default_channel_id,\n               a.agent_uuid AS \"agent_uuid: uuid::Uuid\",\n               COALESCE(f.name, '') AS \"fleet_name!\"\n        FROM agents a\n        LEFT JOIN fleets f ON f.id = a.fleet_id\n        WHERE a.id = $1\n        ",
